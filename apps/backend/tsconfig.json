{
  "extends": "@nursinghome/typescript-config/nestjs",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "removeComments": true,
    "declaration": true,
    "outDir": "./dist",
    "types": ["node", "jest"],
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
