{
  "name": "nursinghome",
  "private": true,
  "packageManager": "npm@11.16.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "deps:fix": "syncpack fix",
    "deps:lint": "syncpack list",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "format:pkg": "syncpack format",
    "format:pkg:check": "syncpack format --check",
    "lint": "turbo run lint",
    "prepare": "npm run build -w @nursinghome/eslint-config",
    "test": "turbo run test"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "syncpack": "^15.3.2",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "braces": "^3.0.3",
    "form-data": "^4.0.1",
    "js-yaml": "^4.2.0",
    "multer": "^2.2.0",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "uuid": "^11.1.1"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "tailwindcss": "^4.3.2"
  }
}
