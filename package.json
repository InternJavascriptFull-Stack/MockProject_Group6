{
  "name": "nursinghome",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "prepare": "npm run build -w @nursinghome/eslint-config"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9",
    "jiti": "^2.4.2",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "braces": "^3.0.3",
    "form-data": "^4.0.1",
    "js-yaml": "^4.2.0",
    "multer": "^2.2.0",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "uuid": "^11.1.1"
  }
}
